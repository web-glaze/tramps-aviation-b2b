# ─────────────────────────────────────────────────────────────────────────────
# Tramps Aviation B2B — .gitignore
# ─────────────────────────────────────────────────────────────────────────────
# Stack:  Next.js 14 (App Router) · TypeScript · Tailwind · Zustand · axios
# OS targets:  Windows · macOS · Linux  (multi-developer team)
#
# Sections:
#   1. Dependencies           (node_modules, lock alternates, pnpm/yarn dirs)
#   2. Build output           (.next, /out, /build, /dist, .turbo)
#   3. Environment / secrets  (.env*, key files, *.pem)
#   4. Testing & coverage     (coverage, .nyc_output)
#   5. Caches                 (TS, ESLint, Prettier, SWC, Webpack, Vercel)
#   6. Logs & temp            (*.log, *.tmp, *.swp)
#   7. IDE / editor metadata  (.vscode, .idea, *.suo, *.ntvs*)
#   8. OS junk                (.DS_Store, Thumbs.db, desktop.ini)
#   9. Project-specific       (uploads, screenshots, scratch files)
# ─────────────────────────────────────────────────────────────────────────────


# ── 1. Dependencies ─────────────────────────────────────────────────────────
node_modules/
jspm_packages/
.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnpm-store/

# Don't commit lockfiles for *other* package managers — we use yarn,
# so yarn.lock is committed (it's NOT listed below). Block the others.
package-lock.json
pnpm-lock.yaml
bun.lockb


# ── 2. Build output ─────────────────────────────────────────────────────────
.next/
out/
build/
dist/
.turbo/
.vercel/
storybook-static/


# ── 3. Environment / secrets ────────────────────────────────────────────────
# Never commit anything that might hold an API key, JWT secret, or DB URL.
.env
.env.*
!.env.example         # keep the template — renamed properly
!.env.sample
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local

# Cloud / IaC secret files that sometimes land in the repo by accident
*.pem
*.key
*.p12
*.pfx
*.crt
firebase-adminsdk*.json
service-account*.json
gcp-credentials*.json


# ── 4. Testing & coverage ───────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
junit.xml
playwright-report/
playwright/.cache/
test-results/


# ── 5. Caches (TS, lint, format, bundlers) ──────────────────────────────────
*.tsbuildinfo
next-env.d.ts             # auto-generated by `next dev`/`build`
.eslintcache
.stylelintcache
.parcel-cache/
.cache/
.swc/
.webpack/
.rollup.cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.cache-loader/
.fusebox/


# ── 6. Logs & temp ──────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log

*.tmp
*.temp
*.swp
*.swo
*~


# ── 7. IDE / editor metadata ────────────────────────────────────────────────
# VSCode — keep `extensions.json` (recommended team extensions) but ignore
# personal launch / settings.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json

# JetBrains (WebStorm / IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Sublime / Atom / Vim / Emacs
*.sublime-workspace
*.sublime-project
.atom/
.history/
*.swp
*.swo
.\#*


# ── 8. OS junk ──────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ── 9. Project-specific ─────────────────────────────────────────────────────
# Local scratch / WIP folders that occasionally appear in this repo
scratch/
tmp/
*.bak
*.bak.tsx
*.bak.ts

# Large binary uploads that should live on S3, not git
public/uploads/
public/temp/

# Screenshots used during dev review (keep `.gitkeep` if folder must exist)
screenshots/
*.local-screenshot.png

# Generated agent / commission report dumps
reports/*.csv
reports/*.xlsx

# Storybook build artifacts (if added later)
.storybook-out/

# Lighthouse / perf reports
.lighthouseci/
*.lighthouse.html
